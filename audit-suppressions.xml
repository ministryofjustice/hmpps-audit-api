<?xml version="1.0" encoding="UTF-8"?>

<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    <!-- Suppressing as we can't do anything about this, it's the latest version.
      Apache releases a new version every 2 months so Mohamad regularly checking and will update when a fix is out-->
    <suppress>
        <notes><![CDATA[
     file name: parquet-avro-1.17.0.jar
     ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.apache\.parquet/parquet-avro@1.17.0$</packageUrl>
        <cve>CVE-2023-37475</cve>
    </suppress>
    <suppress>
        <notes><![CDATA[
   file name: netty-codec-smtp-4.1.127.Final.jar
   ]]></notes>
        <packageUrl regex="true">^pkg:maven/io\.netty/netty-codec-smtp@.*$</packageUrl>
        <vulnerabilityName>CVE-2025-59419</vulnerabilityName>
    </suppress>
