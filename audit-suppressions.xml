     of being update to version 3.5 so we are suppressing this CVE until a fix is released. https://github.com/apache/parquet-java/issues/3387-->
    <suppress>
        <notes><![CDATA[
   file name: aircompressor-2.0.2.jar
   ]]></notes>
        <packageUrl regex="true">^pkg:maven/io\.airlift/aircompressor@.*$</packageUrl>
        <vulnerabilityName>CVE-2025-67721</vulnerabilityName>
    </suppress>
</suppressions>